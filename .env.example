# ===========================================
# Mama Math - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ── Supabase (Required) ────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── OpenRouter AI (Required for AI Features) ──
# Get your API key from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
VITE_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# ── Vapi Voice AI (Optional) ───────────────
# Get your API key from: https://vapi.ai/
VITE_VAPI_API_KEY=your-vapi-api-key-here

# ── Firebase (Optional - for Cloud Functions) ──
# Only needed if using Firebase Cloud Functions
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
